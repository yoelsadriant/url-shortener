    "aws-cdk": "^2.166.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/test/**/*.test.ts"],
    "transform": {
      "^.+\\.ts$": "ts-jest"

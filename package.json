{
  "name": "url-shortener",
  "private": true,
  "scripts": {
    "up": "docker compose -f services/backend/compose.yml --profile dev up",
    "up:build": "docker compose -f services/backend/compose.yml --profile dev up --build",
    "up:prod": "docker compose -f services/backend/compose.yml --profile prod up --build",
    "down": "docker compose -f services/backend/compose.yml --profile dev --profile prod down",
    "logs": "docker compose -f services/backend/compose.yml logs -f",
    "install:all": "npm --prefix services/backend install && npm --prefix services/frontend install",
    "dev:backend": "npm --prefix services/backend run start:dev",
    "dev:frontend": "npm --prefix services/frontend run dev",
    "build:all": "npm --prefix services/backend run build && npm --prefix services/frontend run build",
    "test:backend": "npm --prefix services/backend test",
    "test:backend:e2e": "npm --prefix services/backend run test:e2e",
    "test:frontend": "npm --prefix services/frontend run test:run",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:load": "docker run --rm -i --network host -e BASE_URL=${BASE_URL:-http://localhost:3000} -v $PWD/tests:/tests grafana/k6 run /tests/redirect-load.js"
  }
}

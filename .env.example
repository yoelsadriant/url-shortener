# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored — never commit it.

# AWS (use "local" for DynamoDB Local)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_ENDPOINT=http://dynamodb-local:8000

# DynamoDB tables
URL_TABLE=urls
URL_USER_INDEX=user-index
USER_TABLE=users
USER_USERNAME_INDEX=username-index

# Backend
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3000
